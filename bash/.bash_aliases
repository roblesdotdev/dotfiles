
# Clear
alias c="clear"
alias cl="clear"

# History
alias h="history"
alias hgrep="history | rgrep"

# List
alias l="ls -lAh"
alias ls="ls -a"
alias ll="ls -al"

# Ping
alias ping="ping -c3"

# Confirmation
alias mv="mv -i"
alias rm="rm -i"

# Memory Info
alias meminfo="free -mlth"
alias psmem="ps auxf | sort -nr -k 4"

# Use `nvim` instead `vim` | `vi` 
alias vi="nvim"
alias vim="nvim"

# Use `bat` instead `cat`
alias cat="bat"
alias cata="bat --show-all"

# Use `htop` instead `top`
alias top="htop"

# Calculator
alias bc="bc -l"

# Create parent directories
alias mkdir="mkdir -pv"

# Resume wget
alias wget="wget -c"
